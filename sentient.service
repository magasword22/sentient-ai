[Unit]
Description=Sentient AI Web Interface
After=network.target ollama.service

[Service]
User=root
WorkingDirectory=/opt/sentient
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/sentient/venv/bin/python3 -m streamlit run /opt/sentient/app.py --server.port 8501 --server.address 0.0.0.0
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
