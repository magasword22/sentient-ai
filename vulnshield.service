[Unit]
Description=VulnShield AI Web Interface
After=network.target ollama.service

[Service]
User=root
WorkingDirectory=/opt/vulnshield
ExecStart=/opt/vulnshield/venv/bin/streamlit run /opt/vulnshield/app.py --server.port 8501 --server.address 0.0.0.0
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
